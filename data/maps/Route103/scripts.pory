script RiverFerryManNotThatEntry {
	lockall
	setflag (FLAG_SAFE_FOLLOWER_MOVEMENT)
	applymovement (34, moves(face_player))
	applymovement (OBJ_EVENT_ID_PLAYER, moves(face_down * 1))
	msgbox(format("Not so fast, young one...! If you want to board, do it after me."))
	applymovement (OBJ_EVENT_ID_PLAYER, moves(walk_left * 1))
	waitmovement
	releaseall
	}

script FisherGuruRoute103 {
	lock
	if (var(VAR_FISHERPROGRESS103) == 0)
	{

	setflag (FLAG_SAFE_FOLLOWER_MOVEMENT)

	playse (SE_M_SURF)
	waitse
	playse (SE_PIN)
	applymovement (38, moves(emote_exclamation_mark))
	msgbox(format("Sssh... did you hear that? Something... SOMETHING IS COMING!"))

	applymovement (OBJ_EVENT_ID_PLAYER, moves(face_right))

	playse (SE_M_DIVE)
	waitse
	clearflag (mudcrabcrawdaunt)
	addobject (39)
	playse (SE_SHINY)
	waitse

	playmoncry (SPECIES_CRAWDAUNT, CRY_MODE_ENCOUNTER)
	msgbox(format("CRAAAAAAW!!"))
	removeobject (39)
	setflag (mudcrabcrawdaunt)
	playse (SE_M_DIVE)
	waitse

	msgbox(format("AAH, CRAB BASKETS!"))
	applymovement (OBJ_EVENT_ID_PLAYER, moves(face_up))
	msgbox(format("That was the LEGENDARY MUD CRAB of Route 103 - I've been looking for it for WEEKS! \p But I was
	so awe-struck... that I could not do anything!! \p Still, this can't be a coincidence - you
	both showed up at the same time!! \p HMM... my intuition tells me it saw something in you. But
	then it left disappointed. \p But we can fix that. Here, take THIS!"))

	giveitem (ITEM_OLD_ROD)

	msgbox(format("I want you to take that rod and fish at least FIVE SPECIES OF POKÉMON! \p WHY?
	Because only then will the LEGENDARY MUDCRAB judge you as worthy, and show itself again!
	\p Do not question my intuition - just embrace it, and fulfil your destiny!!"))
	setvar(VAR_FISHERPROGRESS103 , 1)
	goto (finishfisherscript)



}
	
	if ((var(VAR_FISHERPROGRESS103) == 1) || (var(VAR_FISHERPROGRESS103) == 2) || (var(VAR_FISHERPROGRESS103) == 3))
	{
	msgbox(format("AHOY! How's the FISHING going!?"))
	dynmultichoice(0, 0, TRUE, 3, 0, DYN_MULTICHOICE_CB_NONE, "About your request...", "Did you see the Mud Crab?", "How's it going?")

		if(var(VAR_RESULT) == 0){
			if (var(VAR_FISHERPROGRESS103) == 1){
				getcaughtmon (SPECIES_SMOTHQUIL)
				if(var(VAR_RESULT) == TRUE){
				msgbox(format("Ah, you've fished at least 5 Pokémon? Good, GOOD! \p I'm confident the
				Legendary Mud Crab will acknowledge you and show up. \p Let's wait a bit!"))
				applymovement (OBJ_EVENT_ID_PLAYER, moves(face_right))

				fadeoutbgm (1)
				fadescreen (FADE_TO_BLACK)
				msgbox (format("You and the fisher wait in a long, uncomfortable silence..."))
				fadescreen (FADE_FROM_BLACK)
				fadeinbgm (1)

				msgbox (format("Hmm... I should have known. Such a measly fishing test... \p Is NOT ENOUGH
				to make the Mud Crab acknowledge you! \p I suppose I've got no choice... here, TAKE THIS!"))
				applymovement (OBJ_EVENT_ID_PLAYER, moves(face_up))
				giveitem (ITEM_GOOD_ROD)

				msgbox (format("I want you to use that rod to bring me a BIG PEARL! \p If you are a true
				fisher... you will know how. \p Do that, and I'm sure next time the Mud Crab will show itself!"))

				setvar(VAR_FISHERPROGRESS103 , 2)
				goto (finishfisherscript)
				}

				if(var(VAR_RESULT) == FALSE){
				msgbox(format("Like I said, I need you to fish 5 species of Pokémon! \p If you are the fisher
				the Mud Crab believes you to be, you shouldn't need any guidance! \p O-of course I could give it,
				but that would defeat the purpose!"))
				goto (finishfisherscript)
				}

			}

			if (var(VAR_FISHERPROGRESS103) == 2){
				if (checkitem (ITEM_BIG_PEARL)  == TRUE)
				{msgbox(format("pearl"))



				goto (finishfisherscript)
				// Shiny Crawdaunt shows up
				}
				else 
				{msgbox(format("no pearl"))
				goto (finishfisherscript)
				}
			}
		}

		if(var(VAR_RESULT) == 1){
			msgbox(format("Regrettably, I haven't. Not even the tip of that lustruous, star-shaped crown
			of his... \p But don't worry - he won't swim away easily. \p They say he is forever waiting for a
			trainer who saved his life during the Assault on Route 103. \p Sadly, that trainer died that
			day. They will never meet again... \p In spite of its beastly appearance, the Mud Crab is
			a loyal, tender creature. That's why I wish to catch him, and help him heal!"))
			goto (finishfisherscript)
		}

		if(var(VAR_RESULT) == 2){}
			msgbox(format("Ah, well, aside from the Mud Crab business... not very good, I must say. \p It's
			tough being a fisher in these parts nowadays. The sea is poisoned, the rivers are muddy... \p
			Most of my buddies have moved up north. But me, I like the challenge!"))
			goto (finishfisherscript)
		}
	
	finishfisherscript:
	releaseall}


