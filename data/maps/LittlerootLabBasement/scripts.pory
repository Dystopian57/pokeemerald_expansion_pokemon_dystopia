									setspeaker ([SP_NAME_AIDEE])
									msgbox (format("{PLAYER}, you haven't registered the data for this
									Safemon on your Devon Dex! \pI need that data to figure out how to
									Unsafen it - sorry!"))
									goto (tenthsafemonlistreturn)
									}
									
									}

									
								//WARABBIT UNSAFEN
								if(var(VAR_RESULT) == 2){
								getseenmon (SPECIES_WARABBIT)
									if (var(VAR_RESULT) == TRUE)
								
										{msgbox (format("Uuhm, {PLAYER}...? The Unsafener is not detecting
										this one as a Safemon... \p But I've also never seen or heard of a
