										if (checkitem (ITEM_RARE_CANDY)  == TRUE)
											{msgbox (format("Which you have - excellent! Now, let's see that
											Tamarakku!"))
											setvar (VAR_0x8008, INGAME_TRADE_TOGEPI)
														copyvar (VAR_0x8004, VAR_0x8008)
														specialvar (VAR_0x8009, GetInGameTradeSpeciesInfo)
														special (ChoosePartyMon)
														waitstate
														goto_if_eq (VAR_0x8004, PARTY_NOTHING_CHOSEN, CancelTradeSafemonSelection)
														copyvar (VAR_0x8005, VAR_0x8004)
														specialvar (VAR_RESULT, GetTradeSpecies)
														goto_if_ne (VAR_RESULT, VAR_0x8009, SelectedIncorrectTradeSafemon)
														copyvar (VAR_0x8004, VAR_0x8008)
														special (CreateInGameTradePokemon)
														special (DoInGameTradeScene) 
														waitstate
														createfieldmugshot (MUGSHOT_AIDEE , EMOTE_HAPPY)
														setspeaker ([SP_NAME_AIDEE])
														incrementgamestat (GAME_STAT_RODE_CABLE_CAR)
											
											msgbox (format("It's done! Another Unsafening success - take good care
											of that Togepi!"))
											removeitem (ITEM_RARE_CANDY, 1)
											goto (finishsafemontradescript)
											}
										else {
											setspeaker ([SP_NAME_AIDEE])
											msgbox (format("Of which you don't have any!
											\p Well, check my stock of Unsafening Materials - I
											might just have it!"))
											goto (finishsafemontradescript)
											}}

									
								if (var(VAR_RESULT) == FALSE)
								{playse (SE_RG_HELP_ERROR)
									setspeaker ([SP_NAME_AIDEE])
									msgbox (format("{PLAYER}, you haven't registered the data for this
									Safemon on your Devon Dex! \pI need that data to figure out how to
									Unsafen it - sorry!"))
									goto (ninthsafemonlistreturn)
									}
									
									}
		
			#TENTH PAGE

						if (var(VAR_RESULT) == 3) {
						tenthsafemonlistreturn:
						getseenmon (SPECIES_ROTOM_MONITOR)
						if (var(VAR_RESULT) == TRUE)
						{bufferspeciesname (STR_VAR_1, SPECIES_ROTOM_MONITOR)}
						if (var(VAR_RESULT) == FALSE)
						{bufferspeciesname (STR_VAR_1, SPECIES_NONE)}

						getseenmon (SPECIES_MIMIYURUI)
						if (var(VAR_RESULT) == TRUE)
						{bufferspeciesname (STR_VAR_2, SPECIES_MIMIYURUI)}
						if (var(VAR_RESULT) == FALSE)
						{bufferspeciesname (STR_VAR_2, SPECIES_NONE)}

						getseenmon (SPECIES_WARABBIT)
						if (var(VAR_RESULT) == TRUE)
						{bufferspeciesname (STR_VAR_3, SPECIES_WARABBIT)}
						if (var(VAR_RESULT) == FALSE)
						{bufferspeciesname (STR_VAR_3, SPECIES_NONE)}
					}
					
					msgbox (format("What about one of these?"))
					dynmultichoice(0, 0, TRUE, 5, 0, DYN_MULTICHOICE_CB_NONE, "{STR_VAR_1}", "{STR_VAR_2}", "{STR_VAR_3}", "A different Safemon", "None")
								//ROTOM MONITOR UNSAFEN
								if(var(VAR_RESULT) == 0){
								getseenmon (SPECIES_ROTOM_MONITOR)
									if (var(VAR_RESULT) == TRUE)
								
										{				
										createfieldmugshot (MUGSHOT_AIDEE , EMOTE_POKEBALL)
										setspeaker ([SP_NAME_AIDEE])
										msgbox (format("Rotom Monitor, huh? Well, to unsafen this one we need 
										a {COLOR RED}Good Wrench{COLOR DARK_GRAY}..."))
										
										if (checkitem (ITEM_METAL_COAT)  == TRUE)
											{msgbox (format("Which you have - excellent! Now, let's see that
											Rotom Monitor!"))
											setvar (VAR_0x8008, INGAME_TRADE_ROTOM)
														copyvar (VAR_0x8004, VAR_0x8008)
														specialvar (VAR_0x8009, GetInGameTradeSpeciesInfo)
														special (ChoosePartyMon)
														waitstate
														goto_if_eq (VAR_0x8004, PARTY_NOTHING_CHOSEN, CancelTradeSafemonSelection)
														copyvar (VAR_0x8005, VAR_0x8004)
														specialvar (VAR_RESULT, GetTradeSpecies)
														goto_if_ne (VAR_RESULT, VAR_0x8009, SelectedIncorrectTradeSafemon)
														copyvar (VAR_0x8004, VAR_0x8008)
														special (CreateInGameTradePokemon)
														special (DoInGameTradeScene) 
														waitstate
														createfieldmugshot (MUGSHOT_AIDEE , EMOTE_HAPPY)
														setspeaker ([SP_NAME_AIDEE])
														incrementgamestat (GAME_STAT_RODE_CABLE_CAR)
											
											msgbox (format("It's done! Another Unsafening success - take good care
											of that Rotom!"))
											removeitem (ITEM_METAL_COAT, 1)
											goto (finishsafemontradescript)
											}
										else {
											setspeaker ([SP_NAME_AIDEE])
											msgbox (format("Of which you don't have any!
											\p Well, check my stock of Unsafening Materials - I
											might just have it!"))
											goto (finishsafemontradescript)
											}

									}

										if (var(VAR_RESULT) == FALSE)
										{playse (SE_RG_HELP_ERROR)
											setspeaker ([SP_NAME_AIDEE])
											msgbox (format("{PLAYER}, you haven't registered the data for this
											Safemon on your Devon Dex! \pI need that data to figure out how to
											Unsafen it - sorry!"))
											goto (tenthsafemonlistreturn)
											}
								}

								//MIMIYURUI UNSAFEN
								if(var(VAR_RESULT) == 1){
								getseenmon (SPECIES_MIMIYURUI)
									if (var(VAR_RESULT) == TRUE)
								
										{				
										createfieldmugshot (MUGSHOT_AIDEE , EMOTE_POKEBALL)
										setspeaker ([SP_NAME_AIDEE])
										msgbox (format("Mimiyurui, huh? Well, to unsafen this one we need 
										a {COLOR RED}INSERT ITEM{COLOR DARK_GRAY}..."))
										
										
										if (checkdecor (DECOR_PURACHU_DOLL)  == TRUE)
											{msgbox (format("Which you have - excellent! Now, let's see that
											Mimiyurui!"))
											setvar (VAR_0x8008, INGAME_TRADE_MIMIKYU)
														copyvar (VAR_0x8004, VAR_0x8008)
														specialvar (VAR_0x8009, GetInGameTradeSpeciesInfo)
														special (ChoosePartyMon)
														waitstate
														goto_if_eq (VAR_0x8004, PARTY_NOTHING_CHOSEN, CancelTradeSafemonSelection)
														copyvar (VAR_0x8005, VAR_0x8004)
														specialvar (VAR_RESULT, GetTradeSpecies)
														goto_if_ne (VAR_RESULT, VAR_0x8009, SelectedIncorrectTradeSafemon)
														copyvar (VAR_0x8004, VAR_0x8008)
														special (CreateInGameTradePokemon)
														special (DoInGameTradeScene) 
														waitstate
														createfieldmugshot (MUGSHOT_AIDEE , EMOTE_HAPPY)
														setspeaker ([SP_NAME_AIDEE])
														incrementgamestat (GAME_STAT_RODE_CABLE_CAR)
											
											msgbox (format("It's done! Another Unsafening success - take good care
											of that Mimikyu!"))
											removedecoration (DECOR_PURACHU_DOLL)
											goto (finishsafemontradescript)
											}
										else {
											setspeaker ([SP_NAME_AIDEE])
											msgbox (format("Of which you don't have any!
