script OldaleOutsideOldGuy {
    lockall
    applymovement (13, moves(face_player))
    msgbox(format("If you were wondering... it should be way past autumn now. \p The trees are brown
    because they are sick. It's the Koffing poison the Kantonians doused during
    the war.
    \p Before long, we may not be able to live here anymore..."))
    releaseall
    }

script OldaleTown_GotoTherapy{
	lockall
	special (SpawnCameraObject)
	applymovement(OBJ_EVENT_ID_CAMERA, moves(walk_right * 6))
    waitmovement(0)
	msgbox (format("That's the Devon Learning Center... I should attend the therapy session."))
	special (RemoveCameraObject)
	special (SpawnCameraObject)
	applymovement(OBJ_EVENT_ID_CAMERA, moves(walk_left * 6))
    waitmovement(0)
	special (RemoveCameraObject)
	applymovement (OBJ_EVENT_ID_PLAYER, moves(walk_down * 1))
	waitmovement
	releaseall	
}

script OldaleSharpyCameliaOutDLCCutscene {
    lockall
	setflag (FLAG_SAFE_FOLLOWER_MOVEMENT)
	setspeaker ([SP_NAME_SHARPY])
    createfieldmugshot (MUGSHOT_SHARPY , EMOTE_CONFUSED)
    msgbox(format("Hmm... I don't think we'll find any volunteers here..."))
    
    removefieldmugshot
	setspeaker ([SP_NAME_CAMELIA])
    createfieldmugshot (MUGSHOT_CAMELIA , EMOTE_NORMAL)
    msgbox(format("I hate to agree. Everyone was either scared of Pokémon, a Devon supporter,
    or both."))

    removefieldmugshot
	setspeaker ([SP_NAME_CAMELIA])
    createfieldmugshot (MUGSHOT_CAMELIA , EMOTE_NORMAL)

	checkplayergender
	if(var(VAR_RESULT) == MALE){
     msgbox(format("Someone caught my eye though... and he's behind you now."))
    }


    if(var(VAR_RESULT) == FEMALE){
    msgbox(format("Someone caught my eye though... and she's behind you now."))
    }

    removefieldmugshot
    applymovement (18, moves(face_left, emote_exclamation_mark))
    playse (SE_PIN)
    waitse
	setspeaker ([SP_NAME_SHARPY])
    createfieldmugshot (MUGSHOT_SHARPY , EMOTE_SHOCK)

	if(var(VAR_RESULT) == MALE){
    msgbox(format("O-oh, hello there mister! You're just in time!"))
    }
    if(var(VAR_RESULT) == FEMALE){
    msgbox(format("O-oh, hello there miss! You're just in time!"))
    }
    removefieldmugshot
    applymovement (18, moves(walk_left * 2))
	applymovement (OBJ_EVENT_ID_PLAYER, moves(face_right))
    waitmovement
	setspeaker ([SP_NAME_SHARPY])
    createfieldmugshot (MUGSHOT_SHARPY , EMOTE_NORMAL)
    msgbox(format("Would you like to join us fight Devon? You know Devon Co., right?"))

    removefieldmugshot
	setspeaker ([SP_NAME_SHARPY])
    createfieldmugshot (MUGSHOT_SHARPY , EMOTE_CONFUSED)
    msgbox(format("They're turning Pokémon into lame Safemon, making things expensive, and doing many other bad things!"))

    removefieldmugshot
	setspeaker ([SP_NAME_SHARPY])
    createfieldmugshot (MUGSHOT_SHARPY , EMOTE_NORMAL)
    msgbox(format("Camelia and I want to stop them - well, us and old man Norman! \p Oh, name is Sharpy,
    by the way! What's yours? {PLAYER}? Cool name!"))

    removefieldmugshot
	setspeaker ([SP_NAME_SHARPY])
    createfieldmugshot (MUGSHOT_SHARPY , EMOTE_POKEBALL)
    msgbox(format("So, will you help us?"))


	dynmultichoice(0, 0, TRUE, 3, 0, DYN_MULTICHOICE_CB_NONE, "Yes", "No")
	waitmessage

        if(var(VAR_RESULT) == 0){
            goto (saidyestoSharpy)
}

        if(var(VAR_RESULT) == 1){
            removefieldmugshot
	        setspeaker ([SP_NAME_SHARPY])
            createfieldmugshot (MUGSHOT_SHARPY , EMOTE_SHOCK)
            msgbox(format("Whaaat!? But you look like a soldier - which means you're strong,
            and brave, right?"))
            
            applymovement (18, moves(face_right))
            removefieldmugshot
            setspeaker ([SP_NAME_CAMELIA])
            createfieldmugshot (MUGSHOT_CAMELIA , EMOTE_CONFUSED)
            msgbox(format("We're not with the Rebels, if that's what you're worried about."))
            
            removefieldmugshot
            setspeaker ([SP_NAME_CAMELIA])
            createfieldmugshot (MUGSHOT_CAMELIA , EMOTE_CONFUSED)
            msgbox(format("Unlike them, we want to change things through peaceful means."))
            
            
            removefieldmugshot
            applymovement (18, moves(face_left))
	        setspeaker ([SP_NAME_SHARPY])
            createfieldmugshot (MUGSHOT_SHARPY , EMOTE_NORMAL)
            msgbox(format("Exactly! So, now that you know that, you'll join us, right?")) 
            
            	dynmultichoice(0, 0, TRUE, 3, 0, DYN_MULTICHOICE_CB_NONE, "Yes", "No")
	            waitmessage

                if(var(VAR_RESULT) == 0){
                    goto (saidyestoSharpy)
                }
                
                    if(var(VAR_RESULT) == 1){
                     removefieldmugshot
	                 setspeaker ([SP_NAME_SHARPY])
                     createfieldmugshot (MUGSHOT_SHARPY , EMOTE_SHOCK)
                     msgbox(format("W-what!? But listen, we have to-"))}  
                
                    removefieldmugshot
                    setspeaker ([SP_NAME_CAMELIA])
                    createfieldmugshot (MUGSHOT_CAMELIA , EMOTE_SAD)
                    msgbox(format("{COLOR LIGHT_GRAY}{SHADOW WHITE}Sigh...{COLOR DARK_GRAY}{SHADOW LIGHT_GRAY} 
                    It's alright, Sharpy. We'll keep looking tomorrow."))

                    removefieldmugshot
                    setspeaker ([SP_NAME_SHARPY])
                    createfieldmugshot (MUGSHOT_SHARPY , EMOTE_SAD)
                    msgbox(format("Grr... you give up too easily, Camelia. But I'm not like that!"))

                    removefieldmugshot
                    setspeaker ([SP_NAME_SHARPY])
                    createfieldmugshot (MUGSHOT_SHARPY , EMOTE_POKEBALL)
                    msgbox(format("You leave me with no other choice... I challenge you... to a BATTLE!"))
                
                    removefieldmugshot
                    setspeaker ([SP_NAME_SHARPY])
                    createfieldmugshot (MUGSHOT_SHARPY , EMOTE_POKEBALL)
                    msgbox(format("If you win, I'll leave you alone forever - but if I do, you'll have to join us!"))

                    removefieldmugshot
                    setspeaker ([SP_NAME_CAMELIA])
                    createfieldmugshot (MUGSHOT_CAMELIA , EMOTE_SAD)
                    msgbox(format("Sharpy, that's essentially harrasment..."))

                    applymovement (18, moves(face_right))
                    removefieldmugshot
                    setspeaker ([SP_NAME_SHARPY])
                    createfieldmugshot (MUGSHOT_SHARPY , EMOTE_NORMAL)
                    msgbox(format("Maybe - but the end justifies the means! W-wait, that's what rebelssay..."))

                    applymovement (18, moves(face_left))
                    removefieldmugshot
                    setspeaker ([SP_NAME_SHARPY])
                    createfieldmugshot (MUGSHOT_SHARPY , EMOTE_POKEBALL)
                    msgbox(format("A-anyway, ome join me in Route 103! I'll be waiting!"))
                    removefieldmugshot

                    playse (SE_FLEE)
                    applymovement (18, moves(walk_fast_down * 1, walk_fast_left * 5, walk_fast_up * 7))
                    waitmovement


                    setflag (saidnotosharpyinoldale)
                    goto (thisguy)
                }
            
            
            saidyestoSharpy:
            removefieldmugshot
	        setspeaker ([SP_NAME_SHARPY])
            createfieldmugshot (MUGSHOT_SHARPY , EMOTE_NORMAL)
            msgbox(format("Awesome - I knew you would just by looking at you!"))

            removefieldmugshot
	        setspeaker ([SP_NAME_SHARPY])
            createfieldmugshot (MUGSHOT_SHARPY , EMOTE_CONFUSED)
            msgbox(format("But there's one thing... Norman told us we'd need strong people..."))

            removefieldmugshot
	        setspeaker ([SP_NAME_SHARPY])
            createfieldmugshot (MUGSHOT_SHARPY , EMOTE_POKEBALL)
            msgbox(format("So we need to battle first - if you win, that means you're strong enough!"))

            removefieldmugshot
	        setspeaker ([SP_NAME_SHARPY])
            createfieldmugshot (MUGSHOT_SHARPY , EMOTE_SAD)
            msgbox(format("We can't battle here though - I don't want to scare any more kids..."))

            removefieldmugshot
	        setspeaker ([SP_NAME_SHARPY])
            createfieldmugshot (MUGSHOT_SHARPY , EMOTE_NORMAL)
            msgbox(format("Come join me in Route 103. I'll be waiting!"))
            

    playse (SE_FLEE)
    applymovement (18, moves(walk_fast_down * 1, walk_fast_left * 5, walk_fast_up * 7))
    waitmovement
    thisguy:
    removefieldmugshot
	setspeaker ([SP_NAME_CAMELIA])
    createfieldmugshot (MUGSHOT_CAMELIA , EMOTE_ANGRY)
    msgbox(format("This guy..."))

    finishOldalekidscutscene:
    removefieldmugshot
    setvar(VAR_OLDALE_PHASE, 2)
    setobjectxy (18, 0, 0)
    setobjectxy (20, 0, 0)
	setflag (sharpynotoutsideDLC)
	clearflag (sharpynotinroute103)
	setflag (sharpycorphishoutsideDLC)
	setflag (camelianotinroute103)
    releaseall
    }

script OldaleCamelia {
    lockall

    if (flag (saidnotosharpyinoldale))
    {

	setflag (FLAG_SAFE_FOLLOWER_MOVEMENT)
	applymovement (17, moves(face_player))
    setspeaker ([SP_NAME_CAMELIA])
    createfieldmugshot (MUGSHOT_CAMELIA , EMOTE_SAD)
    msgbox(format("I'm sorry about him... I know this is a lot to ask, but can you go kick
    that idiot's ass real quick?"))

    removefieldmugshot
	setspeaker ([SP_NAME_CAMELIA])
    createfieldmugshot (MUGSHOT_CAMELIA , EMOTE_NORMAL)
    msgbox(format("You fought in the war, so it should be easy right?"))

    removefieldmugshot
	setspeaker ([SP_NAME_CAMELIA])
    createfieldmugshot (MUGSHOT_CAMELIA , EMOTE_SAD)
    msgbox(format("He won't leave until you battle him, and Norman will be mad if we're not
    back at the dojo soon..."))

    }

    else {

    removefieldmugshot
	setspeaker ([SP_NAME_CAMELIA])
    createfieldmugshot (MUGSHOT_CAMELIA , EMOTE_NORMAL)
    msgbox(format("Don't worry, I'm sure you won't have any issues beating Sharpy."))

    removefieldmugshot
	setspeaker ([SP_NAME_CAMELIA])
    createfieldmugshot (MUGSHOT_CAMELIA , EMOTE_MENACING)
    msgbox(format("I do it all the time, and I have the type disadvantage."))

    }
    removefieldmugshot
    releaseall
    }

