    msgbox(format("We have already secured the southern front, remember!?
    Thanks to your glorious victory!"))

    msgbox(format("Wait... do you need to get ready before the next battle?"))
	    dynmultichoice(0, 0, TRUE, 2, 0, DYN_MULTICHOICE_CB_NONE, "Yes", "No")
