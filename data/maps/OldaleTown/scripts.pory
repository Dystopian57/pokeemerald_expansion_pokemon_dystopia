raw `



`
//OLDALE PHASES
//0: Just arrived
//1: Therapy done
//2: Warehouse cleared
//3: Rival following
//4: Devon block left
//5: Devon warehouse inhabited again

mapscripts OldaleTown_MapScripts {
    MAP_SCRIPT_ON_TRANSITION: DayNightNPC
    MAP_SCRIPT_ON_TRANSITION: OldaleWeather
    MAP_SCRIPT_ON_TRANSITION: GenderedSpriteOldale
    
    MAP_SCRIPT_ON_LOAD: DayNightNPC
    MAP_SCRIPT_ON_LOAD: OldaleWeather
    MAP_SCRIPT_ON_LOAD: GenderedSpriteOldale}
	


script GenderedSpriteOldale {
call(Common_EventScript_SetupRivalGfxId)
}
script FountainCoinSparkle {
    if (!flag (oldalefountainsparkle))
    {dofieldeffectsparkle (10, 9, 1)
    setflag (oldalefountainsparkle)}

    else {release}
    release
}

script BalsamCallAfterWarehouse {

    if (!flag(BalsamtoldtogoseeNorman))
    {
    pokenavcall(format("Prof Balsam: Hey there, {PLAYER}. It's me, Balsam.\p Are you alright?
    Therapy should have finished ages ago, but you haven't returned like we discussed.\p It's
    alright if you want to stretch your legs, but you should have told us. Your grandpa Birch
    was worried sick.\p Since you're feeling adventurous - why don't you go visit your
    other grandpa at Petalburg? \p A change of scenery will do you good. It's very close, but
    give me a call if you get lost."))

	if (var(VAR_LITTLEROOT_PHASE) < 6)
	{msgbox(format("Oh, and we still need help with finding that Voltorb Shard my Aide asked
    you about.\p It's not urgent, but we'd really appreciate it."))}
    

    msgbox(format("It's back to work for me. Take care, {PLAYER}."))}

    else {release}
}

script TimeofDayTest {
	lock
	gettimeofday
		if (var(VAR_0x8000) == TIME_MORNING)
		{msgbox(format("Morning."))
        goto (endoftimeofdaytest)}

		if (var(VAR_0x8000) == TIME_DAY)
		{msgbox(format("Day."))
        goto (endoftimeofdaytest)}

		if (var(VAR_0x8000) == TIME_EVENING)
		{msgbox(format("Evening."))
        goto (endoftimeofdaytest)}

		if (var(VAR_0x8000) == TIME_NIGHT)
		{msgbox(format("Night."))
        goto (endoftimeofdaytest)}
endoftimeofdaytest:
releaseall
}


script OldaleWeather {

	if (var(VAR_OLDALE_PHASE) == 0)
	{setweather (WEATHER_SHADE)
}
	if (var(VAR_OLDALE_PHASE) == 1)
	{setweather (WEATHER_SHADE)
}
	if (var(VAR_OLDALE_PHASE) == 2)
	{setweather (WEATHER_SHADE)
}
}

script ConArtist103Rewards {
	lock
	setflag (FLAG_SAFE_FOLLOWER_MOVEMENT)
	applymovement (34, moves(face_player))
	if (!flag (conartistthanked))
	{
    setflag (conartistthanked)
	msgbox(format("You did me a solid there, champ! You're a pro performer! \p Here's your reward - Jimmy McGligar never goes back on his word!"))
	giveegg (SPECIES_TAMARAKKU)
	playse (MUS_OBTAIN_ITEM)
	msgbox(format("Obtained the Mysterious Egg!"))
    setspeaker ([SP_NAME_JOEL])
	msgbox(format("Look, I know I said I'd give you some cash but... \p All I have is my
	wares! The cash I get when I sell them, duh! \p Speaking of wares - would you like to
	take a look at them?"))

	dynmultichoice(0, 0, TRUE, 2, 0, DYN_MULTICHOICE_CB_NONE, "Yes", "No")
	if(var(VAR_RESULT) == 0){
        setspeaker ([SP_NAME_JOEL])
		msgbox(format("Hehe, of course you do... here's what I got! Only 500 each!"))
		eggoffer:
		dynmultichoice(0, 0, TRUE, 4, 0, DYN_MULTICHOICE_CB_NONE, "Egg Option 1", "Egg Option 2", "Rosy Egg", "Not really")
			if(var(VAR_RESULT) == 0){
			msgbox(format("Egg 1 here"))
            goto (finisheggdeal)
			}

			if(var(VAR_RESULT) == 1){
			msgbox(format("Egg 2 here"))
            goto (finisheggdeal)
			}

			if(var(VAR_RESULT) == 2){
			msgbox(format("Egg 3 here"))
			// believe me, this egg can actually MULTIPLY itself upon hatching! It's a huge
			//investment opportunity. It's a bit more expensive though... 1000. But you can't say no
			//right?
            goto (finisheggdeal)
			}

            if(var(VAR_RESULT) == 2){
			goto (refusedeggs)}

			
	}

	if(var(VAR_RESULT) == 1){
        refusedeggs:
        setspeaker ([SP_NAME_JOEL])
		msgbox(format("Welp, that's your loss. \p I'm off to Petalburg soon, so you'll have to
		walk if you change your mind!"))
        goto (finisheggdeal)
	}}

	else {
        setspeaker ([SP_NAME_JOEL])
		msgbox(format("So? Interested in some eggs?"))
		goto (eggoffer)
	}
	finisheggdeal:
	releaseall
	}


script OldaleVendingMachine {
    lock
    msgbox(format("It's a vending machine."))
    showmoneybox (18, 0)
    dynmultichoice(0, 0, TRUE, 4, 0, DYN_MULTICHOICE_CB_NONE, "Fresh Water - 50¥", "Soda Pop - 70¥", "Strong Coffee - 80¥", "Leave")
    
            //Fresh Water
            if(var(VAR_RESULT) == 0){
            		checkmoney (50)
				if (var(VAR_RESULT) == TRUE) {
                    playse (SE_SHOP)
                    waitse
					updatemoneybox

                    random (4)
                    goto_if_ne (VAR_RESULT, 0, freshwatergotstuck)
                    goto_if_eq (VAR_RESULT, FALSE, gotfreshwater)

                    gotfreshwater:
                    playse (SE_VEND)
					waitse
					removemoney (50)
					msgbox(format("A Fresh Water bottle dropped on the machine's tray."))
                    hidemoneybox
                    giveitem (ITEM_FRESH_WATER)
					
                    random (20)
                    goto_if_ne (VAR_RESULT, 0, endvendingmachine)
                    goto_if_eq (VAR_RESULT, FALSE, gotextrafreshwater)

                    gotextrafreshwater:
                    msgbox(format("An extra Fresh Water bottle dropped on the machine's tray!"))
                    hidemoneybox
					giveitem (ITEM_FRESH_WATER)
                    goto (endvendingmachine)

                    freshwatergotstuck:
                    applymovement (OBJ_EVENT_ID_PLAYER, moves(emote_exclamation_mark))
                    playse (SE_PIN)
                    waitse
                    msgbox(format("The machine does not push the Fresh Water enough for it to fall..."))

                    dynmultichoice(0, 0, TRUE, 2, 0, DYN_MULTICHOICE_CB_NONE, "Shake the machine", "Leave")
                        if(var(VAR_RESULT) == 0){
                        call(MachineShake)
                        goto (gotfreshwater)
                        }

                        if(var(VAR_RESULT) == 0){
                        msgbox(format("The Fresh Water just stays on the verge of falling, mockingly.")
                        goto (endvendingmachine))
                        }
				}

                if (var(VAR_RESULT) == FALSE) {
                  msgbox(format("Not enough money..."))  
                }
            }

            //Soda
            if(var(VAR_RESULT) == 1){
            		checkmoney (70)
				if (var(VAR_RESULT) == TRUE) {
                    playse (SE_SHOP)
                    waitse
					updatemoneybox

                    random (4)
                    goto_if_ne (VAR_RESULT, 0, sodagotstuck)
                    goto_if_eq (VAR_RESULT, FALSE, gotsoda)

                    gotsoda:
                    playse (SE_VEND)
					waitse
					removemoney (70)
					msgbox(format("A Soda dropped on the machine's tray."))
                    hidemoneybox
                    giveitem (ITEM_SODA_POP)
					
                    random (20)
                    goto_if_ne (VAR_RESULT, 0, endvendingmachine)
                    goto_if_eq (VAR_RESULT, FALSE, gotextrasoda)

                    gotextrasoda:
                    msgbox(format("An extra Soda can dropped on the machine's tray!"))
                    hidemoneybox
					giveitem (ITEM_SODA_POP)
                    goto (endvendingmachine)

                    sodagotstuck:
                    applymovement (OBJ_EVENT_ID_PLAYER, moves(emote_exclamation_mark))
                    playse (SE_PIN)
                    waitse
                    msgbox(format("The machine does not push the Soda can enough for it to fall..."))

                    dynmultichoice(0, 0, TRUE, 2, 0, DYN_MULTICHOICE_CB_NONE, "Shake the machine", "Leave")
                        if(var(VAR_RESULT) == 0){
                        call(MachineShake)
                        goto (gotsoda)
                        }

                        if(var(VAR_RESULT) == 0){
                        msgbox(format("The Soda can just stays on the verge of falling, mockingly.")
                        goto (endvendingmachine))
                        }
				}

                if (var(VAR_RESULT) == FALSE) {
                  msgbox(format("Not enough money..."))  
                }
            }

            //Coffee
            if(var(VAR_RESULT) == 2){
            		checkmoney (80)
				if (var(VAR_RESULT) == TRUE) {
                    playse (SE_SHOP)
                    waitse
					updatemoneybox

                    random (4)
                    goto_if_ne (VAR_RESULT, 0, coffeegotstuck)
                    goto_if_eq (VAR_RESULT, FALSE, gotcoffee)

                    gotcoffee:
                    playse (SE_VEND)
					waitse
					removemoney (50)
					msgbox(format("A Strong Coffee can dropped on the machine's tray."))
                    hidemoneybox
                    giveitem (ITEM_HEAL_POWDER)
					
                    random (20)
                    goto_if_ne (VAR_RESULT, 0, endvendingmachine)
                    goto_if_eq (VAR_RESULT, FALSE, gotextracoffee)

                    gotextracoffee:
                    msgbox(format("An extra Strong Coffee can dropped on the machine's tray!"))
                    hidemoneybox
					giveitem (ITEM_HEAL_POWDER)
                    goto (endvendingmachine)

                    coffeegotstuck:
                    applymovement (OBJ_EVENT_ID_PLAYER, moves(emote_exclamation_mark))
                    playse (SE_PIN)
                    waitse
                    msgbox(format("The machine does not push the Strong Coffee enough for it to fall..."))

                    dynmultichoice(0, 0, TRUE, 2, 0, DYN_MULTICHOICE_CB_NONE, "Shake the machine", "Leave")
                        if(var(VAR_RESULT) == 0){
                        call(MachineShake)
                        goto (gotcoffee)
                        }

                        if(var(VAR_RESULT) == 0){
                        msgbox(format("The Strong Coffee just stays on the verge of falling, mockingly.")
                        goto (endvendingmachine))
                        }
				}

                if (var(VAR_RESULT) == FALSE) {
                  msgbox(format("Not enough money..."))  
                }
            }
    
    if(var(VAR_RESULT) == 4){
        goto (endvendingmachine)
    }
    endvendingmachine:
    hidemoneybox
    releaseall
    }


script MachineShake{
	playse (SE_M_REVERSAL) 
	setvar(VAR_0x8004, 2)  //@ vertical pan
	setvar(VAR_0x8005, 6)  //@ horizontal pan
	setvar(VAR_0x8006, 4)  //@ num shakes
	setvar(VAR_0x8007, 4)  //@ shake delay
	special(ShakeCamera)
	}


script OldaleTownSign {
    lock
    msgbox(format("Oldale Town. \n “Where things start off scarce.”"))
    releaseall   
}

script Oldale103Sign {
    lock
    msgbox(format("Route 103 ahead. \p In case of flood, retreat behind the flood gates."))
    releaseall   
}

script OldaleDLCSign {
    lock
    msgbox(format("Devon Learning Center.\n“Come learn in a safe environment.”"))
    releaseall   
}


script Oldale102Sign {
    lock
    msgbox(format("West - Road 002."))
    releaseall      
}

script OldalePeekingOldman {
    lock
    setflag (FLAG_SAFE_FOLLOWER_MOVEMENT)
    msgbox(format("Those Rebel hoodlums... just when we start to get back on our feet,
    they come to ruin things! \p Murkrows, the lot of them!"))
    releaseall
}

script OldaleOutsideHikerGuy {
    lock
    applymovement (13, moves(face_player))
    setflag (FLAG_SAFE_FOLLOWER_MOVEMENT)
	if(var(VAR_JOELQUESTS) == 0)
    {
    msgbox(format("Did you know? My son is top of the class at the DLC! \p He's as sharp as
    his father. He'll make it big in Rustboro one day, I'm sure."))}

	if(var(VAR_JOELQUESTS) == 1)
    {
    msgbox(format("Did you know? My son is top of the class at the DLC! \p He's as sharp as
    his father. He'll make it big in Rustboro one day, I'm sure."))}

	if(var(VAR_JOELQUESTS) == 2)
    {
    msgbox(format("Arf, arf... I tried catching up to my daugther, but she's so fast...!
    \p I hope she doesn't go too far. We are moving to {COLOR BLUE}Rustboro{COLOR DARK_GRAY} today."))}

	if(var(VAR_JOELQUESTS) == 3)
    {
    msgbox(format("My daugther is finally back... I can't wait to get out of
    this place. \p I assure you, it's not what it used to be..."))}

    releaseall
    }

script OldaleOutsideParkNPC {
    lock
	setflag (FLAG_SAFE_FOLLOWER_MOVEMENT)
    applymovement (11, moves(face_player))

    if ((!flag (FLAG_HIDDEN_ITEM_OLDALE_TRASHCAN)) && checkitem (ITEM_ITEMFINDER)  == FALSE)
        {
        msgbox(format("I hear there's people in the Rebel Zone who get crazy rich by finding treasure with their {COLOR BLUE}Object Spotters{COLOR DARK_GRAY}.
        \p Haven't managed to get my hands on one, or I wouldn't be sitting here!"))
        }
    if ((flag (FLAG_HIDDEN_ITEM_OLDALE_TRASHCAN)) && checkitem (ITEM_ITEMFINDER)  == FALSE)
    {
        msgbox(format("So... I saw you digging through that trash can. \p If you need pokeyen,
        you should get an {COLOR BLUE}Object Spotter{COLOR DARK_GRAY} and find scrap to sell. There's lots lying around. \p Other people
        get rich by selling items like ores and pearls, but I wouldn't know where to start looking
        for those."))}
        
    if ((!flag (FLAG_HIDDEN_ITEM_OLDALE_TRASHCAN)) && checkitem (ITEM_ITEMFINDER)  == TRUE)
    {
        msgbox(format("Oh, is that a Devon Radar? That's handy. \p If you're short on pokeyen,
        you should use it as much as you can. You might find some valuables to sell.\p
        Why don't you try it right here? Who knows, you might find something!"))}

    if ((flag (FLAG_HIDDEN_ITEM_OLDALE_TRASHCAN)) && checkitem (ITEM_ITEMFINDER)  == TRUE)
    {
        msgbox(format("Oh, is that a Devon Radar? That's handy. \p If you're short on pokeyen,
        you should use it as much as you can. You might find some valuables to sell.\p
        Hopefully something better than what you found in that trash can... ha-ha-ha!"))}

    release
    }


    //msgbox(format("It's tough being a trader around here lately... tons of competition.\pThere's
    //scammers taking advantage of war tourists, war victims selling their valuables to stay afloat...
    //\p You should be careful where you shop!"))


script OldaleOutsideOldGuy {
    lock
    applymovement (12, moves(face_player))
    msgbox(format("If you were wondering... it should be way past autumn now. \p The trees are brown
    because they are sick. It's the Koffing poison the Kantonians doused during
    the war.
    \p Before long, we may not be able to live here anymore..."))
    releaseall
    }

script OldaleOutsideOldWoman {
    lock
    applymovement (30, moves(face_player))
    msgbox(format("Did you see the greenish rain just now...? \p The Weather Institute says
    it's not harmful on the short-term. But I worry about the long term..."))
    releaseall
    }

script DLCTeacherOutside {
    lock
    applymovement (34, moves(face_player))
	if(var(VAR_OLDALE_PHASE) == 1)
    {msgbox(format("I'm really dying for a smoke here... \p If only those loser Rebels left the Warehouse,
    Devon Co. would start sending supplies again."))}

    if(var(VAR_OLDALE_PHASE) == 2)
    {removeobject (35)
    playse (SE_TRUCK_UNLOAD)
    msgbox(format("{COLOR LIGHT_GRAY}{SHADOW WHITE}Fuu...{COLOR DARK_GRAY}{SHADOW LIGHT_GRAY}
    \p Ah, sorry for blowing the smoke on your face. Haven't smoked in days... \p With the Rebels
    gone, the mart is getting stocked again.\p Was about time!
    {COLOR LIGHT_GRAY}{SHADOW WHITE}Fuu...{COLOR DARK_GRAY}{SHADOW LIGHT_GRAY}"))}
    releaseall  
    }

script OldaleTown_GotoTherapy{
	lock
	setflag (FLAG_SAFE_FOLLOWER_MOVEMENT)
	special (SpawnCameraObject)
	applymovement(OBJ_EVENT_ID_CAMERA, moves(walk_right * 6))
    waitmovement(0)
	msgbox (format("That's the Devon Learning Center... the therapy session should be about to start."))
	special (RemoveCameraObject)
	special (SpawnCameraObject)
	applymovement(OBJ_EVENT_ID_CAMERA, moves(walk_left * 6))
    waitmovement(0)
	special (RemoveCameraObject)
	applymovement (OBJ_EVENT_ID_PLAYER, moves(walk_down * 1))
	waitmovement
	releaseall	
}

script OldaleSharpyCameliaOutDLCCutscene {

    if (flag (sharpycameliaDLCcs))

    {lock
	setflag (FLAG_SAFE_FOLLOWER_MOVEMENT)
	setspeaker ([SP_NAME_SHARPY])
    createfieldmugshot (MUGSHOT_SHARPY , EMOTE_CONFUSED)
    msgbox(format("Hmm... I don't think we'll find any volunteers here..."))
    
    removefieldmugshot
	setspeaker ([SP_NAME_CAMELIA])
    createfieldmugshot (MUGSHOT_CAMELIA , EMOTE_NORMAL)
    msgbox(format("I hate to agree. Everyone was either scared of Pokémon, a Devon supporter,
    or both."))

    removefieldmugshot
	setspeaker ([SP_NAME_CAMELIA])
    createfieldmugshot (MUGSHOT_CAMELIA , EMOTE_NORMAL)

	checkplayergender
	if(var(VAR_RESULT) == MALE){
     msgbox(format("Someone caught my eye though... and he's behind you now."))
    }


    if(var(VAR_RESULT) == FEMALE){
    msgbox(format("Someone caught my eye though... and she's behind you now."))
    }

    removefieldmugshot
    applymovement (17, moves(face_left, emote_exclamation_mark))
    playse (SE_PIN)
    waitse
	setspeaker ([SP_NAME_SHARPY])
    createfieldmugshot (MUGSHOT_SHARPY , EMOTE_SHOCK)

	if(var(VAR_RESULT) == MALE){
    msgbox(format("O-oh, hello there mister! You're just in time!"))
    }
    if(var(VAR_RESULT) == FEMALE){
    msgbox(format("O-oh, hello there miss! You're just in time!"))
    }
    removefieldmugshot
    applymovement (17, moves(walk_left * 2))
	applymovement (OBJ_EVENT_ID_PLAYER, moves(face_right))
    waitmovement
	setspeaker ([SP_NAME_SHARPY])
    createfieldmugshot (MUGSHOT_SHARPY , EMOTE_NORMAL)
    msgbox(format("Would you like to join us fight Devon? You know Devon Co., right?"))

    removefieldmugshot
	setspeaker ([SP_NAME_SHARPY])
    createfieldmugshot (MUGSHOT_SHARPY , EMOTE_CONFUSED)
    msgbox(format("They're turning Pokémon into lame Safemon, making things expensive, and doing many other bad things!"))

    removefieldmugshot
	setspeaker ([SP_NAME_SHARPY])
    createfieldmugshot (MUGSHOT_SHARPY , EMOTE_NORMAL)
    msgbox(format("Camelia and I want to stop them - well, us and our caretaker! \p Oh, name is Sharpy,
    by the way! What's yours? {PLAYER}? Cool name!"))

    removefieldmugshot
	setspeaker ([SP_NAME_SHARPY])
    createfieldmugshot (MUGSHOT_SHARPY , EMOTE_POKEBALL)
    msgbox(format("So, will you help us?"))


	dynmultichoice(0, 0, TRUE, 2, 0, DYN_MULTICHOICE_CB_NONE, "Yes", "No")
	waitmessage

        if(var(VAR_RESULT) == 0){
            goto (saidyestoSharpy)
}

        if(var(VAR_RESULT) == 1){
            removefieldmugshot
	        setspeaker ([SP_NAME_SHARPY])
            createfieldmugshot (MUGSHOT_SHARPY , EMOTE_SHOCK)
            msgbox(format("Whaaat!? But you look like a soldier - which means you're strong,
            and brave, right?"))
            
            applymovement (17, moves(face_right))
            removefieldmugshot
            setspeaker ([SP_NAME_CAMELIA])
            createfieldmugshot (MUGSHOT_CAMELIA , EMOTE_CONFUSED)
            msgbox(format("We're not with the {COLOR RED}Rebels{COLOR DARK_GRAY}, if that's what you're worried about."))
            
            removefieldmugshot
            setspeaker ([SP_NAME_CAMELIA])
            createfieldmugshot (MUGSHOT_CAMELIA , EMOTE_CONFUSED)
            msgbox(format("Unlike them, we want to change things through peaceful means."))
            
            
            removefieldmugshot
            applymovement (17, moves(face_left))
	        setspeaker ([SP_NAME_SHARPY])
            createfieldmugshot (MUGSHOT_SHARPY , EMOTE_NORMAL)
            msgbox(format("Exactly! So, now that you know that, you'll join us, right?")) 
            
            	dynmultichoice(0, 0, TRUE, 3, 0, DYN_MULTICHOICE_CB_NONE, "Yes", "No")
	            waitmessage

                if(var(VAR_RESULT) == 0){
                    goto (saidyestoSharpy)
                }
                
                    if(var(VAR_RESULT) == 1){
                     removefieldmugshot
	                 setspeaker ([SP_NAME_SHARPY])
                     createfieldmugshot (MUGSHOT_SHARPY , EMOTE_SHOCK)
                     msgbox(format("W-what!? But listen, we have to-"))}  
                
                    removefieldmugshot
                    setspeaker ([SP_NAME_CAMELIA])
                    createfieldmugshot (MUGSHOT_CAMELIA , EMOTE_SAD)
                    msgbox(format("{COLOR LIGHT_GRAY}{SHADOW WHITE}Sigh...{COLOR DARK_GRAY}{SHADOW LIGHT_GRAY} 
                    It's alright, Sharpy. We'll keep looking tomorrow."))

                    removefieldmugshot
                    setspeaker ([SP_NAME_SHARPY])
                    createfieldmugshot (MUGSHOT_SHARPY , EMOTE_SAD)
                    applymovement (18, moves(face_right))
                    msgbox(format("Grr... you give up too easily, Camelia. But I'm not like that!"))

                    removefieldmugshot
                    setspeaker ([SP_NAME_SHARPY])
                    createfieldmugshot (MUGSHOT_SHARPY , EMOTE_POKEBALL)
                    applymovement (18, moves(face_left))
                    msgbox(format("You leave me with no other choice... I challenge you... to a BATTLE!"))
                
                    removefieldmugshot
                    setspeaker ([SP_NAME_SHARPY])
                    createfieldmugshot (MUGSHOT_SHARPY , EMOTE_POKEBALL)
                    msgbox(format("If you win, I'll leave you alone forever - but if I do, you'll have to join us!"))

                    removefieldmugshot
                    setspeaker ([SP_NAME_CAMELIA])
                    createfieldmugshot (MUGSHOT_CAMELIA , EMOTE_SAD)
                    msgbox(format("Sharpy, that's essentially harrasment..."))

                    applymovement (18, moves(face_right))
                    removefieldmugshot
                    setspeaker ([SP_NAME_SHARPY])
                    createfieldmugshot (MUGSHOT_SHARPY , EMOTE_NORMAL)
                    msgbox(format("Maybe - but the end justifies the means! W-wait, that's {COLOR RED}Rebels{COLOR DARK_GRAY} talk..."))

                    applymovement (18, moves(face_left))
                    removefieldmugshot
                    setspeaker ([SP_NAME_SHARPY])
                    createfieldmugshot (MUGSHOT_SHARPY , EMOTE_POKEBALL)
                    msgbox(format("A-anyway, come to Route 103! I'll be waiting!"))
                    removefieldmugshot

                    playse (SE_FLEE)
                    applymovement (17, moves(walk_fast_down * 1, walk_fast_left * 5, walk_fast_up * 7))
                    waitmovement


                    setflag (saidnotosharpyinoldale)
                    goto (thisguy)
                }
            
            
            saidyestoSharpy:
            removefieldmugshot
	        setspeaker ([SP_NAME_SHARPY])
            createfieldmugshot (MUGSHOT_SHARPY , EMOTE_NORMAL)
            msgbox(format("Awesome - I knew you would just by looking at you!"))

            removefieldmugshot
	        setspeaker ([SP_NAME_SHARPY])
            createfieldmugshot (MUGSHOT_SHARPY , EMOTE_CONFUSED)
            msgbox(format("But there's one thing... he told us we'd need strong people..."))

            removefieldmugshot
	        setspeaker ([SP_NAME_SHARPY])
            createfieldmugshot (MUGSHOT_SHARPY , EMOTE_POKEBALL)
            msgbox(format("So we need to battle first - if you win, that means you're strong enough!"))

            removefieldmugshot
	        setspeaker ([SP_NAME_SHARPY])
            createfieldmugshot (MUGSHOT_SHARPY , EMOTE_SAD)
            msgbox(format("We can't battle here though - I don't want to scare any more kids..."))

            removefieldmugshot
	        setspeaker ([SP_NAME_SHARPY])
            createfieldmugshot (MUGSHOT_SHARPY , EMOTE_NORMAL)
            msgbox(format("Come join me in Route 103. I'll be waiting!"))
            

    playse (SE_FLEE)
    applymovement (17, moves(walk_fast_down * 1, walk_fast_left * 5, walk_fast_up * 7))
    waitmovement
    thisguy:
    removefieldmugshot
	setspeaker ([SP_NAME_CAMELIA])
    createfieldmugshot (MUGSHOT_CAMELIA , EMOTE_ANGRY)
    msgbox(format("This guy..."))

    finishOldalekidscutscene:
    removefieldmugshot
    //setvar(VAR_OLDALE_PHASE, 1)
    setobjectxy (17, 0, 0)
    //setobjectxy (20, 0, 0)
    clearflag (sharpycameliaDLCcs)
	setflag (sharpynotoutsideDLC)
	clearflag (sharpynotinroute103)
	setflag (sharpycorphishoutsideDLC)
	setflag (camelianotinroute103)
    setflag (finishedtherapy)
    releaseall
    }
    
else {release}
    
    }

script OldaleCamelia {
    lock

    if (flag (saidnotosharpyinoldale))
    {

	setflag (FLAG_SAFE_FOLLOWER_MOVEMENT)
	applymovement (17, moves(face_player))
    setspeaker ([SP_NAME_CAMELIA])
    createfieldmugshot (MUGSHOT_CAMELIA , EMOTE_SAD)
    msgbox(format("I'm sorry about him... I know this is a lot to ask, but can you go kick
    that idiot's ass real quick?"))

    removefieldmugshot
	setspeaker ([SP_NAME_CAMELIA])
    createfieldmugshot (MUGSHOT_CAMELIA , EMOTE_NORMAL)
    msgbox(format("You fought in the war, so it should be easy right?"))

    removefieldmugshot
	setspeaker ([SP_NAME_CAMELIA])
    createfieldmugshot (MUGSHOT_CAMELIA , EMOTE_SAD)
    msgbox(format("He won't leave until you battle him, and Norman will be mad if we're not
    back at the dojo soon..."))

    }

    else {

    removefieldmugshot
	setspeaker ([SP_NAME_CAMELIA])
    createfieldmugshot (MUGSHOT_CAMELIA , EMOTE_NORMAL)
    msgbox(format("Don't worry, I'm sure you won't have any issues beating Sharpy."))

    removefieldmugshot
	setspeaker ([SP_NAME_CAMELIA])
    createfieldmugshot (MUGSHOT_CAMELIA , EMOTE_MENACING)
    msgbox(format("I do it all the time, and I have the type disadvantage."))

    }
    removefieldmugshot
    releaseall
    }



text DevonGruntFOutro{
