script OldaleDevonGrunts { //karen and jerry
    lock
	setflag (FLAG_SAFE_FOLLOWER_MOVEMENT)
	if(var(VAR_OLDALE_PHASE) == 1 && !flag (Sharpydefeatedat103))
        {
        applymovement (14, moves(face_player, walk_in_place_right * 1))
        msgbox(format("I'm sorry, but we can't let anyone through until the
        {COLOR RED}Rebels{COLOR DARK_GRAY} occupying {COLOR GREEN}Oldale Warehouse{COLOR DARK_GRAY},
        are dealt with."))
        applymovement (15, moves(face_player, walk_in_place_right * 1))
        msgbox(format("We can't allow these criminals to get closer to New Rustboro... but don't worry!\p
        Reinforcements from Devon HQ are currently on the way."))
        applymovement (14, moves(face_player, walk_in_place_right * 1))
        msgbox(format("Yup! With the current pace of administrative protocols, they should be here in about 6 months."))
        }

	if(var(VAR_OLDALE_PHASE) == 1 && flag (Sharpydefeatedat103))
       {applymovement (14, moves(face_player, walk_in_place_right * 1))
        msgbox(format("Damn kids, they were fast... by the time I grabbed my Devon Ball, they had
        sprinted right past me!"))

        applymovement (15, moves(walk_in_place_up * 1, face_up))
        msgbox(format("
        {COLOR LIGHT_GRAY}{SHADOW WHITE}Dude... you were just checking your Devon Nav.
        {COLOR DARK_GRAY}{SHADOW LIGHT_GRAY}"))

        applymovement (14, moves(walk_in_place_down * 1, face_down))
        msgbox(format("{COLOR LIGHT_GRAY}{SHADOW WHITE}... can we not? We're in front of a civilian!
        {COLOR DARK_GRAY}{SHADOW LIGHT_GRAY}"))
        applymovement (14, moves(face_right))
        applymovement (15, moves(face_right))

        }

	if(var(VAR_OLDALE_PHASE) == 2)
       {applymovement (14, moves(face_player, walk_in_place_right * 1))
        msgbox(format("Hello there, civilian! We have great news! \pThose pesky {COLOR RED}Rebels{COLOR DARK_GRAY}
        have finally left Oldale Warehouse. The town is safe again!"))

        applymovement (15, moves(walk_in_place_up * 1, face_up))
        msgbox(format("They must have caught wind of reinforcements coming, and didn't feel like
        spending the rest of their lives on {COLOR RED}Dewford Prison{COLOR DARK_GRAY}."))
        applymovement (15, moves(face_right))
        applymovement (14, moves(face_player, walk_in_place_right * 1))
        msgbox(format("Most likely! So... I suppose you want to go through Road 002?"))
	    dynmultichoice(0, 0, TRUE, 2, 0, DYN_MULTICHOICE_CB_NONE, "Yes", "No")

        if(var(VAR_RESULT) == 0){
        msgbox(format("I see... well, I'm sorry to say... \p In the Rebel Zone, when it's not one thing,
        it's the other, you know?"))
        applymovement (15, moves(walk_in_place_right * 1))
        msgbox(format("We have one of our scientists searching Road 002 for a very dangerous Pokémon.
        \p It's the next species on the list of Pokémon to be {COLOR BLUE}safened{COLOR DARK_GRAY}, and we can't let his work be
        disturbed"))

        applymovement (14, moves(face_player, walk_in_place_right * 1))
        msgbox(format("I'm afraid so. But don't worry - these tasks usually take from 3 to 4 months.
        \p And what's a little waiting if it means Hoenn becomes safer?"))
        }

        if(var(VAR_RESULT) == 1){
        msgbox(format("Grand, then please enjoy this shith-... I mean, this cozy, cute sleepy town!")) 
        }
        applymovement (14, moves(face_right))
        applymovement (15, moves(face_right))

        clearflag (rivalappearsinOldale)


        }

        trainerbattle_two_trainers (TRAINER_OLDALEDEVONGRUNT_F, DevonGruntFOutro, TRAINER_OLDALEDEVONGRUNT_M, DevonGruntMOutro)
    
        setflag (devonsdontblock102)
    releaseall
}

script OldaleRival {
        lock
	    setflag (FLAG_SAFE_FOLLOWER_MOVEMENT)
        msgbox(format("{PLAYER}... I saw you talking with those enemy soldiers just now.\p Don't you
        KNOW by now!? You cannot reason with the enemy."))
        msgbox(format("You can only {COLOR RED}FIGHT{COLOR DARK_GRAY} it!"))
        msgbox(format("But I understand. It was two versus one. Don't worry, I am here now."))
        msgbox(format("Let's show those Kantonians they can't take our country! LEAD THE WAY, {PLAYER}."))

        setvar(VAR_OLDALE_PHASE, 3)

