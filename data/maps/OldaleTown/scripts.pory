script SamanthaGetSnacksCutscene {

    if (!flag (Samanthagotsnacks))
    {
    lock
    setspeaker ([SP_NAME_SAMANTHA])
    applymovement (OBJ_EVENT_ID_NPC_FOLLOWER, moves(walk_in_place_up * 2))
    msgbox (format("A-ah... here we are, {PLAYER}! Give me a moment..."))
    applymovement (OBJ_EVENT_ID_PLAYER, moves(walk_right * 1, face_up))
    applymovement (OBJ_EVENT_ID_NPC_FOLLOWER, moves(walk_up * 2, walk_right * 2, face_up))
    setspeaker ([SP_NAME_SAMANTHA])
    msgbox (format("Hmm... I'll have some of these..."))
    applymovement (OBJ_EVENT_ID_NPC_FOLLOWER, moves(walk_in_place_up * 1))
    playse (SE_VEND) 
    setspeaker ([SP_NAME_SAMANTHA])
    msgbox (format("And of these..."))
    applymovement (OBJ_EVENT_ID_NPC_FOLLOWER, moves(walk_in_place_up * 1))
    playse (SE_VEND)
    waitse
    applymovement (OBJ_EVENT_ID_NPC_FOLLOWER, moves(walk_in_place_up * 1))
    playse (SE_VEND) 
    setspeaker ([SP_NAME_SAMANTHA])
    msgbox (format("O-oh, and these too...!"))
    applymovement (OBJ_EVENT_ID_NPC_FOLLOWER, moves(walk_in_place_up * 1))
    playse (SE_VEND)
    waitse
    applymovement (OBJ_EVENT_ID_NPC_FOLLOWER, moves(walk_in_place_up * 1))
    playse (SE_VEND) 
    waitse
    applymovement (OBJ_EVENT_ID_NPC_FOLLOWER, moves(walk_in_place_up * 1))
    playse (SE_VEND) 
    waitse
    waitmovement (OBJ_EVENT_ID_NPC_FOLLOWER)

    applymovement (OBJ_EVENT_ID_NPC_FOLLOWER, moves(walk_left * 1, face_down))
    waitmovement (OBJ_EVENT_ID_NPC_FOLLOWER)
    msgbox (format("Hehehe... I've got tons. We can go back. \p T-thank you..."))

    setflag (Samanthagotsnacks)

    releaseall
}

else {release}

}

script SamanthaShake{
	playse (SE_VEND) 
	setvar(VAR_0x8004, 2)  //@ vertical pan
	setvar(VAR_0x8005, 6)  //@ horizontal pan
	setvar(VAR_0x8006, 4)  //@ num shakes
	setvar(VAR_0x8007, 4)  //@ shake delay
	special(ShakeCamera)
