                        }
                    
                } } 

        
        //NO LOANED TMS!
        if(!(flag(loanedprotectTM) && flag(loanedsafeguardTM) && flag(loanedreflectTM)))
        {
        loantmoffer:
        msgbox(format("These are the TMs we have currently available for loans."))
        dynmultichoice(0, 0, TRUE, 4, 0, DYN_MULTICHOICE_CB_NONE, "'TM 17 - Protect'", "'TM 20 - Safeguard'", "'TM 33 - Reflect'", "I changed my mind") 
            if(var(VAR_RESULT) == 0){
            msgbox(format("Of course - I have a copy right here!"))
	        applymovement (9, moves (face_left, face_up))
            giveitem (ITEM_TM_PROTECT)
            setflag (loanedprotectTM)
            msgbox(format("Hope you enjoy it! Please return it when you're finished with it."))
            goto (finishloanscript)
            }

            if(var(VAR_RESULT) == 1){
            msgbox(format("Of course - I have a copy right here!"))
	        applymovement (9, moves (face_left, face_up))
            giveitem (ITEM_TM_SAFEGUARD)
            setflag (loanedsafeguardTM)
            msgbox(format("Hope you enjoy it! Please return it when you're finished with it."))
            goto (finishloanscript)
            }

            if(var(VAR_RESULT) == 2){
            msgbox(format("Of course - I have a copy right here!"))
	        applymovement (9, moves (face_left, face_up))
            giveitem (ITEM_TM_REFLECT)
            setflag (loanedreflectTM)
            msgbox(format("Hope you enjoy it! Please return it when you're finished with it."))
            goto (finishloanscript)
            }

            if(var(VAR_RESULT) == 3){
            msgbox(format("Fair enough. Perhaps you'd like to loan something else?"))
            goto (loantypechoice)
            }}}

    if(var(VAR_RESULT) == 2){
        msgbox(format("It's easy! You can loan one book and one TM at any given time, at no cost. \p If you have
        loaned a book, you'll need to return it before loaning a new one. Same goes for TMs. \p Should you lose the loaned item, you
        will need to pay a fine before loaning anything else. So we encourage you to take good care
        of loans. \p We are constantly updating our loan collection, so you should come check it out
        often. \p So, now that you know how it works..."))
        goto (loantypechoicewithtext)
        }

        if(var(VAR_RESULT) == 3){
        msgbox(format("I'll be here if you change your mind!"))}

        finishloanscript:
        closemessage
        releaseall
}


script OLDLibraryGuyDLC {
    lockall
	setflag (FLAG_SAFE_FOLLOWER_MOVEMENT)
	applymovement (9, moves(face_player))
    msgbox(format("Welcome! This is the Devon Learning Center's library. \p You can read any
    of the books here, but you need to be enrolled to take them on a loan - sorry!"))
	applymovement (9, moves (face_up))
    releaseall
}

script TeacherdeskDLC {
    lockall
    msgbox(format("The book on top features a Psyduck on its cover, and is titled
    'Therapy for Beginners.'"))
    releaseall
}

script BlackBoardDLC {
    lockall
	setflag (FLAG_SAFE_FOLLOWER_MOVEMENT)
	if (flag (DLCmathresolved)){
    msgbox(format("The math problem is resolved"))
    }
	if (!flag (DLCmathresolved)){
    msgbox(format("The board contains an unanswered math problem from a previous lesson..."))

    msgbox(format("I have ¥2404, and I buy two Devon Balls for ¥210 each. How much do I have left?"))
    dynmultichoice(0, 0, TRUE, 3, 0, DYN_MULTICHOICE_CB_NONE, "¥2194", "¥1984", "¥2025", "I don't know")
	waitmessage

	if(var(VAR_RESULT) == 0){
    msgbox(format("You write ¥2194 on the blackboard."))
	applymovement (6, moves(face_player))
	applymovement (OBJ_EVENT_ID_PLAYER, moves(face_left))
    msgbox(format("Uhm... that's not correct. Would you mind not writing wrong answers on the
    board? \n Thank you."))
	applymovement (6, moves(face_down))
    }

	if(var(VAR_RESULT) == 1){
    msgbox(format("You write ¥1984 on the blackboard."))
	applymovement (6, moves(face_player))
	applymovement (OBJ_EVENT_ID_PLAYER, moves(face_left))
    msgbox(format("Oh, that's correct! You're good with numbers."))
	applymovement (6, moves(face_up))
	applymovement (OBJ_EVENT_ID_PLAYER, moves(face_up))
    msgbox(format("I like math problems... they always have a single right answer.
    \p If only the world worked like that."))
	applymovement (6, moves(face_down))
    waitmovement (6)
    setflag (DLCmathresolved)
    }

	if(var(VAR_RESULT) == 2){
    msgbox(format("You write ¥2025 on the blackboard."))
	applymovement (6, moves(face_player))
	applymovement (OBJ_EVENT_ID_PLAYER, moves(face_left))
    msgbox(format("Uhm... that's not correct. Would you mind not writing wrong answers on the
    board? \n Thank you."))
	applymovement (6, moves(face_down))
    }

	if(var(VAR_RESULT) == 2){
    msgbox(format("Better not to write anything..."))
    }
    releaseall}
}

