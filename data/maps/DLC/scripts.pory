mapscripts DLC_MapScripts {
    MAP_SCRIPT_ON_LOAD: DLC_TVOn}

script DLC_TVOn {
	special (TurnOnTVScreen)
	}

script OldaleDLC_GoToSeatForTherapyLeft {
	lockall
	clearflag (FLAG_SAFE_FOLLOWER_MOVEMENT)
	special (SpawnCameraObject)
	applymovement(OBJ_EVENT_ID_CAMERA, moves(walk_up * 2))
    waitmovement(0)
	special (RemoveCameraObject)
    msgbox(format("Ah, there you are... {PLAYER}, is it? \p Please sit down - the session is
    about to start."))
	applymovement (OBJ_EVENT_ID_PLAYER, moves(walk_up * 1, walk_right * 2, face_up))
    goto (starttherapycutscene)
}

script OldaleDLC_GoToSeatForTherapyRight {
	lockall
	clearflag (FLAG_SAFE_FOLLOWER_MOVEMENT)
	special (SpawnCameraObject)
	applymovement(OBJ_EVENT_ID_CAMERA, moves(walk_up * 2))
    waitmovement(0)
	special (RemoveCameraObject)
    msgbox(format("Ah, there you are... {PLAYER}, is it? \p Please sit down - the session is
    about to start."))
	applymovement (OBJ_EVENT_ID_PLAYER, moves(walk_up * 1, walk_right * 1, face_up))
    goto (starttherapycutscene)
}

script OldaleTown_DLC_TherapyCutscene{
    starttherapycutscene:
    msgbox(format("As I was saying, we are going to start by watching some pictures of Kantonian
    Pokémon, and sharing what feelings they evoke in us."))
	showmonpic(SPECIES_VENUSAUR, 10,3)
	playmoncry(SPECIES_VENUSAUR, CRY_MODE_NORMAL) 
    msgbox(format("Let's begin with you, {PLAYER}. Take a look at this picture."))
    hidemonpic
    msgbox(format("What do you think about the Pokémon in it?"))
    dynmultichoice(0, 0, TRUE, 3, 0, DYN_MULTICHOICE_CB_NONE, "It's cool", "Looks dangerous", "I don't know")
    hidemonpic
    playse (SE_PIN)
    applymovement (8, moves (emote_exclamation_mark, walk_in_place_up * 2))
    waitmovement

	if (var(VAR_RESULT) == 0) {
    msgbox(format("Cool!? That Pokémon poisoned my daugther during the war! It's horrible!")) 
}

    if (var(VAR_RESULT) == 1) {
    msgbox(format("I agree! That Pokémon poisoned my daugther during the war! It's horrible!")) 
    }

    if (var(VAR_RESULT) == 2) {
    msgbox(format("Well, I do know! That Pokémon poisoned my daugther during the war! It's horrible!")) 
    }

    applymovement (6, moves (walk_in_place_down * 2)) 
    waitmovement
    msgbox(format("You are correct, sir... Venusaurs are very dangerous. \p Thankfully, Devon Co.
    has safened all Bulbasaurs in Hoenn to Bulbasynths, so that they hurt no more people."))
    applymovement (8, moves (walk_in_place_up * 2))
    waitmovement
    msgbox(format("Ah, thank goodness..."))

    applymovement (6, moves (walk_in_place_down * 1))
    waitmovement
	showmonpic(SPECIES_CHARIZARD, 10,3)
	playmoncry(SPECIES_CHARIZARD, CRY_MODE_NORMAL) 
    msgbox(format("Let's continue... who wants to share their thoughts about this one?"))
    hidemonpic
    playse (SE_PIN)
    applymovement (7, moves (emote_exclamation_mark, walk_in_place_up * 2))
    waitmovement
    msgbox(format("O-oh, that one... t-that one burned my house...! Aaah, it's scary..."))

    playse (SE_M_DIZZY_PUNCH)
    applymovement (3, moves (emote_question_mark, walk_in_place_up * 2))
    waitmovement
	createfieldmugshot (MUGSHOT_CAMELIA , EMOTE_CONFUSED)
	setspeaker ([SP_NAME_CAMELIA])
    msgbox(format("Huh? Nonsense, that's a splendid Fire type."))

    playse (SE_PIN)
    applymovement (7, moves (emote_exclamation_mark, face_left))
    waitmovement
    removefieldmugshot
    msgbox(format("W-what?"))

    applymovement (6, moves (walk_in_place_down * 1))
    waitmovement
    msgbox(format("Now now, let us be tolerant with... differences of opinion."))
    showmonpic(SPECIES_BLASTOISE, 10,3)
	playmoncry(SPECIES_BLASTOISE, CRY_MODE_NORMAL)
    applymovement (7, moves (face_up))
    msgbox(format("Let's see about the last one - the water CANNON Pokémon, Blastoise."))
    hidemonpic

    playse (SE_PIN)
    applymovement (1, moves (emote_exclamation_mark, walk_in_place_up * 1))
    waitmovement
    msgbox(format("U-uwaah, nooo... t-those are the bad turtles...!"))

    applymovement (6, moves (walk_in_place_down * 2)) 
    waitmovement
    msgbox(format("Precisely. The Kantonians used many Blastoise on the Assault on Route 103,
    and they almost flooded Oldale Town. \p Once more, it was thanks to Devon Co.'s swift action,
    that a flood gate was built and..."))

    playse (SE_PIN)
    applymovement (2, moves (emote_exclamation_mark, walk_in_place_up * 2))
    waitmovement
    removefieldmugshot
	createfieldmugshot (MUGSHOT_SHARPY , EMOTE_NORMAL)
	setspeaker ([SP_NAME_SHARPY])
    msgbox(format("Hey, I know that one! That's a cool as heck Blastoise! \p I love how their
    Hydropumps sound..."))
    playse (SE_PIN)

    removefieldmugshot
	createfieldmugshot (MUGSHOT_SHARPY , EMOTE_NORMAL)
	setspeaker ([SP_NAME_SHARPY])
    applymovement (1, moves (face_left, emote_double_exclamation_mark))
    msgbox(format("BANG BANG!"))

	setspeaker (NULL)
    applymovement (1, moves (walk_in_place_left * 10))
    removefieldmugshot
    msgbox(format("N-nooo...!!"))

    removefieldmugshot
	createfieldmugshot (MUGSHOT_SHARPY , EMOTE_CONFUSED)
	setspeaker ([SP_NAME_SHARPY])
    msgbox(format("No? Hmm, you're right... it's not a 'bang' it's more like a..."))
    playse (SE_M_HYDRO_PUMP)

    removefieldmugshot
	createfieldmugshot (MUGSHOT_SHARPY , EMOTE_POKEBALL)
	setspeaker ([SP_NAME_SHARPY])
    applymovement (2, moves (jump_in_place_up * 2))
    msgbox(format("BWAHM BWAHM!"))
    removefieldmugshot
	setspeaker (NULL)
    applymovement (1, moves (walk_fast_left * 1, walk_fast_down * 4))
    playse (SE_FLEE)
    msgbox(format("AAAAAHH...!!"))
    waitse
    applymovement (4, moves (face_left, face_down))
    applymovement (5, moves (face_right, face_down))
    applymovement (7, moves (face_left, face_down))
    applymovement (8, moves (face_right, face_down))
    playse (SE_DOOR)
    waitse
    playse (SE_M_METRONOME)
    applymovement (2, moves (emote_question_mark, face_down))
    waitmovement
    waitse
    removeobject (1)
    waitmovement
    applymovement (6, moves (walk_in_place_down * 1))
    waitmovement
    applymovement (4, moves (face_up))
    applymovement (5, moves (face_up))
    applymovement (7, moves (face_up))
    applymovement (8, moves (face_up))
    msgbox(format("{COLOR LIGHT_GRAY}{SHADOW WHITE}Sigh...{COLOR DARK_GRAY}{SHADOW LIGHT_GRAY}
    I think we will finish this session early. \p Next time, everyone please be mindful of
    others' feelings."))

    applymovement (3, moves (face_right))
    waitmovement
    applymovement (2, moves (face_left)) 
    waitmovement
	createfieldmugshot (MUGSHOT_CAMELIA , EMOTE_SAD)
	setspeaker ([SP_NAME_CAMELIA])
    msgbox(format("Let's go, Sharpy... this was a waste of time."))
    removefieldmugshot
    applymovement (2, moves (walk_right * 1, walk_down *2))
    applymovement (3, moves (walk_right * 2, walk_down *2))
    waitmovement
    playse (SE_DOOR)
    waitse
    removeobject (2)
    removeobject (3)

	special (SpawnCameraObject)
	applymovement(OBJ_EVENT_ID_CAMERA, moves(walk_down * 2))
    waitmovement(0)
	clearflag (sharpynotoutsideDLC)
	clearflag (camelianotoutsideDLC)
	setflag (sharpynotinsideDLC)
	setflag (camelianotinsideDLC)
	special (RemoveCameraObject)
	waitmovement

	setvar(VAR_OLDALE_PHASE, 1)
	releaseall	
}


script LittleKidDLC {
    lockall
	setflag (FLAG_SAFE_FOLLOWER_MOVEMENT)
	applymovement (5, moves(face_player))
    //msgbox(format("I don't like Vinesors... Vensuros...? \n I don't know... but I think Pokémon
    //are scary."))
    checkplayergender
        if(var(VAR_RESULT) == MALE){
        msgbox(format("Hello mister! Want to see my drawing?"))
        }
        if(var(VAR_RESULT) == FEMALE){
        msgbox(format("Hello miss! Want to see my drawing?"))
        }
    dynmultichoice(0, 0, TRUE, 2, 0, DYN_MULTICHOICE_CB_NONE, "Yes", "No")
        if(var(VAR_RESULT) == 0){
        showmonpic(SPECIES_PIKACHU_BELLE, 10,3)
        msgbox(format("Look - I drew Munchies! It's my Snorlax! Well... it was my Snorlax.
        \p Munchie used to be small, but then it EVOLVED! And mom got scared of it.
        \p So we said goodbye to Munchy - we released him. Munchy and I were very sad...
        \pWhen I become a trainer, I'll go find him, and give him tons of yummy things to eat!”"))
        }
        if(var(VAR_RESULT) == 1){
        msgbox(format("Hehe - okay! Your loss!"))
        }
	applymovement (5, moves (face_up))
    releaseall
}


script FatManDLC {
    lockall
	setflag (FLAG_SAFE_FOLLOWER_MOVEMENT)
	applymovement (7, moves(face_player))
    msgbox(format("It's true! I lived in Rustboro, and some fire Pokémon burned the apartment
    building I lived in. \p I had to come back here with my parents. I miss the city."))
	applymovement (7, moves (face_up))
    releaseall
}



script SleepingKidDLC {
    lock
	setflag (FLAG_SAFE_FOLLOWER_MOVEMENT)
	applymovement (4, moves(face_player))
    msgbox(format("ZZZZ... \n ... Huh? Is Math class over? I think I overslept..."))
	applymovement (4, moves (face_up))
    releaseall
}

script GirlNotebookDLC {
    lock
    msgbox(format("It's the notebook the scared girl left behind.\p Next to some classroom notes,
    there's a drawing of a man with a white hat, rescuing a little girl from drowning."))
    releaseall
}

script SleepingBoyNotebookDLC {
    lock
    msgbox(format("The notebook has barely any notes, and is covered in drool."))
    releaseall
}

script SnorlaxKidNotebookDLC {
    lock
    showmonpic(SPECIES_PIKACHU_BELLE, 10,3)
    msgbox(format("It's a drawing of a Snorlax, sleeping soundly.."))
    //msgbox(format("The notebook contains many Pokémon names, most of them typed wrong."))
    hidemonpic
    releaseall
}


script TeacherDLC {
    lockall
	setflag (FLAG_SAFE_FOLLOWER_MOVEMENT)
	applymovement (6, moves(face_player))
    msgbox(format("{COLOR LIGHT_GRAY}{SHADOW WHITE}Sigh...{COLOR DARK_GRAY}{SHADOW LIGHT_GRAY}
    I shouldn't have come to teach to this backwater town. \p But the bonus is so juicy..."))
	applymovement (6, moves (face_down))
    releaseall
}


script LibraryGuyDLC {
    lockall
	setflag (FLAG_SAFE_FOLLOWER_MOVEMENT)
	applymovement (9, moves(face_player))
    msgbox(format("Welcome! This is the Devon Learning Center's library."))
    loantypechoicewithtext:
    msgbox(format("Would you like to loan anything?"))
    loantypechoice:
    dynmultichoice(0, 0, TRUE, 4, 0, DYN_MULTICHOICE_CB_NONE, "Loan a book", "Loan a TM", "How do loans work?", "No, thank you")


        if(var(VAR_RESULT) == 0){

            //LOANED BOOK CHECK

            //FIRE BOOK CHECK
            if (flag (loanedfirebook)){
            msgbox(format("Oh, my record shows you have already loaned 'The History of Mt. Chimney'. \p You
            need to return it before loaning any more books. Is that okay?"))
            dynmultichoice(0, 0, TRUE, 3, 0, DYN_MULTICHOICE_CB_NONE, "Yes", "No", "I lost it...")
            
                if(var(VAR_RESULT) == 0){
                msgbox(format("Very well, I'll take that off your hands then. You can loan a new book now!"))
                removeitem (ITEM_FLAME_PLATE)
                clearflag (loanedfirebook)
                goto (loanbookoffer)
                }

                if(var(VAR_RESULT) == 1){
                msgbox(format("Understandable! You can return it when you've finished with it."))
                goto (loantypechoicewithtext)
                }

                if(var(VAR_RESULT) == 2){
                msgbox(format("Oh, that's unfortunate... \p If you want to continue loaning, you'll need
                to refund the loss - which is 5000¥"))

                    dynmultichoice(0, 0, TRUE, 2, 0, DYN_MULTICHOICE_CB_NONE, "I will pay", "Not right now")
                        if(var(VAR_RESULT) == 0){
                        checkmoney (100)
                            if (var(VAR_RESULT) == TRUE) {
                            removemoney (5000)
                            msgbox(format("Thank you. Please take better care of loans from now on. You
                            may now loan a new book."))
                            clearflag (loanedfirebook)
                            goto (loanbookoffer)
                            }
                            
                            if (var(VAR_RESULT) == FALSE) {
                            msgbox(format("You don't seem to have enough funds... please return when
                            you procure them!")) 
                            goto (loantypechoicewithtext)
                            }}

                        if(var(VAR_RESULT) == 1){
                        msgbox(format("Very well... we'll eagerly await for your refunding."))
                        goto (loantypechoicewithtext)
                        }
                    
                } } 

            //GRASS BOOK CHECK

            if (flag (loanedgrassbook)){
            msgbox(format("Oh, my record shows you have already loaned On Fortree's Deforestation. \p You
            need to return it before loaning any more books. Is that okay?"))
            dynmultichoice(0, 0, TRUE, 3, 0, DYN_MULTICHOICE_CB_NONE, "Yes", "No", "I lost it...")
            
                if(var(VAR_RESULT) == 0){
                msgbox(format("Very well, I'll take that off your hands then. You can loan a new book now!"))
                removeitem (ITEM_MEADOW_PLATE)
                clearflag (loanedgrassbook)
                goto (loanbookoffer)
                }

                if(var(VAR_RESULT) == 1){
                msgbox(format("Understandable! You can return it when you've finished with it."))
                goto (loantypechoicewithtext)
                }

                if(var(VAR_RESULT) == 2){
                msgbox(format("Oh, that's unfortunate... \p If you want to continue loaning, you'll need
                to refund the loss - which is 5000¥"))

                    dynmultichoice(0, 0, TRUE, 2, 0, DYN_MULTICHOICE_CB_NONE, "I will pay", "Not right now")
                        if(var(VAR_RESULT) == 0){
                        checkmoney (100)
                            if (var(VAR_RESULT) == TRUE) {
                            removemoney (5000)
                            msgbox(format("Thank you. Please take better care of loans from now on. You
                            may now loan a new book."))
                            clearflag (loanedgrassbook)
                            goto (loanbookoffer)
                            }
                            
                            if (var(VAR_RESULT) == FALSE) {
                            msgbox(format("You don't seem to have enough funds... please return when
                            you procure them!")) 
                            goto (loantypechoicewithtext)
                            }}

                        if(var(VAR_RESULT) == 1){
                        msgbox(format("Very well... we'll eagerly await for your refunding."))
                        goto (loantypechoicewithtext)
                        }
                    
                } } 


            //ELECTRIC BOOK CHECK

            if (flag (loanedelectricbook)){
            msgbox(format("Oh, my record shows you have already loaned 'New Mauville - What Went Wrong'. \p You
            need to return it before loaning any more books. Is that okay?"))
            dynmultichoice(0, 0, TRUE, 3, 0, DYN_MULTICHOICE_CB_NONE, "Yes", "No", "I lost it...")
            
                if(var(VAR_RESULT) == 0){
                msgbox(format("Very well, I'll take that off your hands then. You can loan a new book now!"))
                removeitem (ITEM_ZAP_PLATE)
                clearflag (loanedelectricbook)
                goto (loanbookoffer)
                }

                if(var(VAR_RESULT) == 1){
                msgbox(format("Understandable! You can return it when you've finished with it."))
                goto (loantypechoicewithtext)
                }

                if(var(VAR_RESULT) == 2){
                msgbox(format("Oh, that's unfortunate... \p If you want to continue loaning, you'll need
                to refund the loss - which is 5000¥"))

                    dynmultichoice(0, 0, TRUE, 2, 0, DYN_MULTICHOICE_CB_NONE, "I will pay", "Not right now")
                        if(var(VAR_RESULT) == 0){
                        checkmoney (100)
                            if (var(VAR_RESULT) == TRUE) {
                            removemoney (5000)
                            msgbox(format("Thank you. Please take better care of loans from now on. You
                            may now loan a new book."))
                            clearflag (loanedelectricbook)
                            goto (loanbookoffer)
                            }
                            
                            if (var(VAR_RESULT) == FALSE) {
                            msgbox(format("You don't seem to have enough funds... please return when
                            you procure them!")) 
                            goto (loantypechoicewithtext)
                            }}

                        if(var(VAR_RESULT) == 1){
                        msgbox(format("Very well... we'll eagerly await for your refunding."))
                        goto (loantypechoicewithtext)
                        }
                    
                } } 
            
            //NO BOOKS LOANED!
            if(!(flag(loanedfirebook) && flag(loanedgrassbook) && flag(loanedelectricbook)))
            {
            
            loanbookoffer:
            msgbox(format("These are the books we have currently available for loans."))

            dynmultichoice(0, 0, TRUE, 4, 0, DYN_MULTICHOICE_CB_NONE, "'The History of Mt. Chimney'", "'On Fortree's Deforestation'", "'New Mauville - What Went Wrong?'", "I changed my mind")

                if(var(VAR_RESULT) == 0){
                msgbox(format("Interested in geology? Then this is a great pick. Here you go!"))
                applymovement (9, moves (face_left))
                waitmovement
                applymovement (9, moves (face_up))
                giveitem (ITEM_FLAME_PLATE)
                setflag (loanedfirebook)
                msgbox(format("Hope you enjoy it! Please return it when you're finished with it."))
                goto (finishloanscript)
                    }}

                if(var(VAR_RESULT) == 1){
                msgbox(format("A concerning ecological study - but I am sure Devon has plans to avoid the worst."))
                applymovement (9, moves (face_left, face_up))
                giveitem (ITEM_MEADOW_PLATE)
                setflag (loanedgrassbook)
                msgbox(format("Hope you enjoy it! Please return it when you're finished with it."))
                goto (finishloanscript)
                }

                if(var(VAR_RESULT) == 2){
                msgbox(format("One should learn from the past to avoid repeating it... here!"))
                applymovement (9, moves (face_left, face_up))
                giveitem (ITEM_ZAP_PLATE)
                setflag (loanedgrassbook)
                msgbox(format("Hope you enjoy it! Please return it when you're finished with it."))
                goto (finishloanscript)
                }

                if(var(VAR_RESULT) == 3){
                msgbox(format("Fair enough. Perhaps you'd like to loan something else?"))
                goto (loantypechoice)
                }}




        if(var(VAR_RESULT) == 1){

        //LOANED TM CHECK

            //PROTECT TM CHECK
            if (flag (loanedprotectTM)){
            msgbox(format("Oh, my record shows you have already loaned TM 17 - Protect. \p You
            need to return it before loaning any more TMs. Is that okay?"))
            dynmultichoice(0, 0, TRUE, 3, 0, DYN_MULTICHOICE_CB_NONE, "Yes", "No", "I lost it...")
            
                if(var(VAR_RESULT) == 0){
                msgbox(format("Very well, I'll take that off your hands then. You can loan a new TM now!"))
                removeitem (ITEM_TM_PROTECT)
                clearflag (loanedprotectTM)
                goto (loantmoffer)
                }

                if(var(VAR_RESULT) == 1){
                msgbox(format("Understandable! You can return it when you've finished with it."))
                goto (loantypechoicewithtext)
                }

                if(var(VAR_RESULT) == 2){
                msgbox(format("Oh, that's unfortunate... \p If you want to continue loaning, you'll need
                to refund the loss - which is 5000¥"))

                    dynmultichoice(0, 0, TRUE, 2, 0, DYN_MULTICHOICE_CB_NONE, "I will pay", "Not right now")
                        if(var(VAR_RESULT) == 0){
                        checkmoney (100)
                            if (var(VAR_RESULT) == TRUE) {
                            removemoney (5000)
                            msgbox(format("Thank you. Please take better care of loans from now on. You
                            may now loan a new TM."))
                            clearflag (loanedprotectTM)
                            goto (loantmoffer)
                            }
                            
                            if (var(VAR_RESULT) == FALSE) {
                            msgbox(format("You don't seem to have enough funds... please return when
                            you procure them!")) 
                            goto (loantypechoicewithtext)
                            }}

                        if(var(VAR_RESULT) == 1){
                        msgbox(format("Very well... we'll eagerly await for your refunding."))
                        goto (loantypechoicewithtext)
                        }
                    
                } } 

            //SAFEGUARD TM CHECK
            if (flag (loanedsafeguardTM)){
            msgbox(format("Oh, my record shows you have already loaned TM 20 - Safeguard. \p You
            need to return it before loaning any more TMs. Is that okay?"))
            dynmultichoice(0, 0, TRUE, 3, 0, DYN_MULTICHOICE_CB_NONE, "Yes", "No", "I lost it...")
            
                if(var(VAR_RESULT) == 0){
                msgbox(format("Very well, I'll take that off your hands then. You can loan a new TM now!"))
                removeitem (ITEM_TM_SAFEGUARD)
                clearflag (loanedsafeguardTM)
                goto (loantmoffer)
                }

                if(var(VAR_RESULT) == 1){
                msgbox(format("Understandable! You can return it when you've finished with it."))
                goto (loantypechoicewithtext)
                }

                if(var(VAR_RESULT) == 2){
                msgbox(format("Oh, that's unfortunate... \p If you want to continue loaning, you'll need
                to refund the loss - which is 5000¥"))

                    dynmultichoice(0, 0, TRUE, 2, 0, DYN_MULTICHOICE_CB_NONE, "I will pay", "Not right now")
                        if(var(VAR_RESULT) == 0){
                        checkmoney (100)
                            if (var(VAR_RESULT) == TRUE) {
                            removemoney (5000)
                            msgbox(format("Thank you. Please take better care of loans from now on. You
                            may now loan a new TM."))
                            clearflag (loanedsafeguardTM)
                            goto (loantmoffer)
                            }
                            
                            if (var(VAR_RESULT) == FALSE) {
                            msgbox(format("You don't seem to have enough funds... please return when
                            you procure them!")) 
                            goto (loantypechoicewithtext)
                            }}

                        if(var(VAR_RESULT) == 1){
                        msgbox(format("Very well... we'll eagerly await for your refunding."))
                        goto (loantypechoicewithtext)
                        }
                    
                } } 


            //REFLECT TM CHECK
            if (flag (loanedreflectTM)){
            msgbox(format("Oh, my record shows you have already loaned TM 33 - Reflect. \p You
            need to return it before loaning any more TMs. Is that okay?"))
            dynmultichoice(0, 0, TRUE, 3, 0, DYN_MULTICHOICE_CB_NONE, "Yes", "No", "I lost it...")
            
                if(var(VAR_RESULT) == 0){
                msgbox(format("Very well, I'll take that off your hands then. You can loan a new TM now!"))
                removeitem (ITEM_TM_REFLECT)
                clearflag (loanedreflectTM)
                goto (loantmoffer)
                }

                if(var(VAR_RESULT) == 1){
                msgbox(format("Understandable! You can return it when you've finished with it."))
                goto (loantypechoicewithtext)
                }

                if(var(VAR_RESULT) == 2){
                msgbox(format("Oh, that's unfortunate... \p If you want to continue loaning, you'll need
                to refund the loss - which is 5000¥"))

                    dynmultichoice(0, 0, TRUE, 2, 0, DYN_MULTICHOICE_CB_NONE, "I will pay", "Not right now")
                        if(var(VAR_RESULT) == 0){
                        checkmoney (100)
                            if (var(VAR_RESULT) == TRUE) {
                            removemoney (5000)
                            msgbox(format("Thank you. Please take better care of loans from now on. You
                            may now loan a new TM."))
                            clearflag (loanedreflectTM)
                            goto (loantmoffer)
                            }
                            
                            if (var(VAR_RESULT) == FALSE) {
                            msgbox(format("You don't seem to have enough funds... please return when
                            you procure them!")) 
                            goto (loantypechoicewithtext)
                            }}

                        if(var(VAR_RESULT) == 1){
                        msgbox(format("Very well... we'll eagerly await for your refunding."))
                        goto (loantypechoicewithtext)
                        }
                    
                } } 

        
        //NO LOANED TMS!
        if(!(flag(loanedprotectTM) && flag(loanedsafeguardTM) && flag(loanedreflectTM)))
        {
        loantmoffer:
        msgbox(format("These are the TMs we have currently available for loans."))
        dynmultichoice(0, 0, TRUE, 4, 0, DYN_MULTICHOICE_CB_NONE, "'TM 17 - Protect'", "'TM 20 - Safeguard'", "'TM 33 - Reflect'", "I changed my mind") 
            if(var(VAR_RESULT) == 0){
            msgbox(format("Of course - I have a copy right here!"))
	        applymovement (9, moves (face_left, face_up))
            giveitem (ITEM_TM_PROTECT)
            setflag (loanedprotectTM)
            msgbox(format("Hope you enjoy it! Please return it when you're finished with it."))
            goto (finishloanscript)
            }

            if(var(VAR_RESULT) == 1){
            msgbox(format("Of course - I have a copy right here!"))
	        applymovement (9, moves (face_left, face_up))
            giveitem (ITEM_TM_SAFEGUARD)
            setflag (loanedsafeguardTM)
            msgbox(format("Hope you enjoy it! Please return it when you're finished with it."))
            goto (finishloanscript)
            }

            if(var(VAR_RESULT) == 2){
            msgbox(format("Of course - I have a copy right here!"))
	        applymovement (9, moves (face_left, face_up))
            giveitem (ITEM_TM_REFLECT)
            setflag (loanedreflectTM)
            msgbox(format("Hope you enjoy it! Please return it when you're finished with it."))
            goto (finishloanscript)
            }

            if(var(VAR_RESULT) == 3){
            msgbox(format("Fair enough. Perhaps you'd like to loan something else?"))
            goto (loantypechoice)
            }}}

    if(var(VAR_RESULT) == 2){
        msgbox(format("It's easy! You can loan one book and one TM at any given time, at no cost. \p If you have
        loaned a book, you'll need to return it before loaning a new one. Same goes for TMs. \p Should you lose the loaned item, you
        will need to pay a fine before loaning anything else. So we encourage you to take good care
        of loans. \p We are constantly updating our loan collection, so you should come check it out
        often. \p So, now that you know how it works..."))
        goto (loantypechoicewithtext)
        }

        if(var(VAR_RESULT) == 3){
        msgbox(format("I'll be here if you change your mind!"))}

        finishloanscript:
        closemessage
        releaseall
}


script OLDLibraryGuyDLC {
