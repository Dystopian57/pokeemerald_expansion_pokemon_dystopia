                            goto (loantypechoicewithtext)
                            }}

                        if(var(VAR_RESULT) == 1){
                        msgbox(format("Very well... we'll eagerly await for your refunding."))
                        goto (loantypechoicewithtext)
                        }
                    
                } } 


            //REFLECT TM CHECK
            if (flag (loanedreflectTM)){
