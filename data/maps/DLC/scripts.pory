                    dynmultichoice(0, 0, TRUE, 2, 0, DYN_MULTICHOICE_CB_NONE, "I will pay", "Not right now")
                        if(var(VAR_RESULT) == 0){
                        checkmoney (100)
                            if (var(VAR_RESULT) == TRUE) {
                            removemoney (5000)
                            msgbox(format("Thank you. Please take better care of loans from now on. You
                            may now loan a new TM."))
                            clearflag (loanedprotectTM)
                            goto (loantmoffer)
                            }
                            
                            if (var(VAR_RESULT) == FALSE) {
                            msgbox(format("You don't seem to have enough funds... please return when
                            you procure them!")) 
                            goto (loantypechoicewithtext)
                            }}

                        if(var(VAR_RESULT) == 1){
                        msgbox(format("Very well... we'll eagerly await for your refunding."))
                        goto (loantypechoicewithtext)
                        }
                    
                } } 

            //SAFEGUARD TM CHECK
            if (flag (loanedsafeguardTM)){
            msgbox(format("Oh, my record shows you have already loaned TM 20 - Safeguard. \p You
            need to return it before loaning any more TMs. Is that okay?"))
            dynmultichoice(0, 0, TRUE, 3, 0, DYN_MULTICHOICE_CB_NONE, "Yes", "No", "I lost it...")
            
                if(var(VAR_RESULT) == 0){
                msgbox(format("Very well, I'll take that off your hands then. You can loan a new TM now!"))
                removeitem (ITEM_TM_SAFEGUARD)
