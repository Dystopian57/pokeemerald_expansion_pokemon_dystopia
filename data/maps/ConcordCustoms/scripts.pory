raw `
ConcordCustoms_MapScripts::
	.byte 0

`


script ConcordWageSlaveAtPhone {
	lock
	setflag (FLAG_SAFE_FOLLOWER_MOVEMENT)
	if (!flag (concordwageslave ))
	
	{

	msgbox(format("I-I'm sorry sir... yes sir... Concord bridge is closed, so I can't
	won't be able to attend the Rustboro meeting... \p ... I... I'm fired? B-but sir...! Please
	be reasonable, I...! \p Sir...? Hello? SIR!? \p ..."))

	playse (SE_M_EXPLOSION)
	setvar(VAR_0x8004, 2)  //@ vertical pan
	setvar(VAR_0x8005, 6)  //@ horizontal pan
	setvar(VAR_0x8006, 4)  //@ num shakes
	setvar(VAR_0x8007, 4)  //@ shake delay
	special(ShakeCamera)
	
	msgbox(format("THAT FILTHY PIG! What am I supposed to do now!? MY FAMILY DEPENDS ON ME!"))
	applymovement (2, moves(face_player))
	msgbox(format("And what do YOU want!? Screw you too!!"))
	trainerbattle_no_intro(TRAINER_CONCORDWAGESLAVE , ConcordWageSlave_Outro)
	
	
	}

	if (flag (concordwageslave))
	
	{
	msgbox(format("I shouldn't have snapped at you like that. I was just really frustrated.
	\p I don't know what I'm going to do now. I guess wait here a bit to figure it out."))
	}

	release}

	text ConcordWageSlave_Outro{
		"Ooof... I... I'm sorry..."}


script ConcordFemaleDevon {
	lock
	setflag (FLAG_SAFE_FOLLOWER_MOVEMENT)
	applymovement (3, moves(face_player))
	if (!flag (conartistescaped))
	{
	msgbox(format("This is not a place to idle. If you're not going to cross the customs,
	you should leave."))
	}

	else {
	msgbox(format("We appreciate your help when we dealt with that con artist. \p He makes a profit
	off smuggling Pokémon eggs, in and out the Internment Zone. \p If he shows his mug around here again,
	we'll catch him for sure!"))
	}}


script ConcordCustomsClerk {
	lock
	setflag (FLAG_SAFE_FOLLOWER_MOVEMENT)
	msgbox(format("I'm sorry, I can't let you through unless you have a {COLOR BLUE}Devon Visa{COLOR DARK_GRAY}.
	\p Applications for visas are currently closed to the general public, but us at Devon Co. will inform as promptly as they are open anew."))
	release

}

script ConcordCustomsWaterDude {
	lock
	setflag (FLAG_SAFE_FOLLOWER_MOVEMENT)
	applymovement (4, moves(face_player))
	msgbox(format("I just tried to bribe the customs officer to let me through... with some {COLOR BLUE}Fresh Water{COLOR DARK_GRAY}.
	\p He looked at me as if I was crazy. \p I don't know why I thought that would work, it was kinda stupid, haha..."))
	release

}


script ConcordCustomsClerkStops0 {
	lock
	setflag (FLAG_SAFE_FOLLOWER_MOVEMENT)
	
	checkplayergender
	if(var(VAR_RESULT) == MALE){
		msgbox(format("Excuse me, sir. Would you be so kind as to approach the counter?"))
	}
	if(var(VAR_RESULT) == FEMALE){
		msgbox(format("Excuse me, sir. Would you be so kind as to approach the counter?"))
	}

	applymovement (OBJ_EVENT_ID_PLAYER, moves(walk_left * 1, face_up))
	waitmovement (OBJ_EVENT_ID_PLAYER)
	msgbox(format("Hmm... you don't have a {COLOR BLUE}Devon Visa{COLOR DARK_GRAY}, do you? \p If that's the
	case, I'm afraid I can't let you through. \p Applications for visas are currently closed to the general
	public, but us at Devon Co. will inform as promptly as they are open anew."))
	release
}


